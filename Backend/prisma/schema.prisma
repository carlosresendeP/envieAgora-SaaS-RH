

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

model Company {
  id          String   @id @default(uuid())
  nome             String?
  razaoSocial String
  cnpj        String   @unique

  // Novos campos para Onboarding e Contexto
  onboardingStep   Int      @default(1)
  contextoEmpresa  String?  @db.Text
  perfilRitmo      String?  // Ex: Acelerado, Analítico
  valores          String[] // Array de strings para cultura
  logoUrl          String?

  // Endereço
  cep        String?
  logradouro String?
  cidade     String?
  estado     String?

  // Onboarding: e-mails de colaboradores para convite de mapeamento
  teamEmails String[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  jobs        Job[]
  applications     Application[]
  organograma      OrganogramaNode[]
}

model User {
  id        String   @id @default(uuid())
  companyId String
  nome      String
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())

  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([companyId])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

enum JobStatus {
  ABERTA
  FECHADA
  PAUSADA
}

model Job {
  id           String    @id @default(uuid())
  titulo       String
  descricao    String    @db.Text
  requisitos   String?   @db.Text
  salario      Decimal?  @db.Decimal(10, 2)
  status       JobStatus @default(ABERTA)

  // Novos campos para IA e Gestão
  liderId         String?       // ID do gestor no organograma
  jdGerada        String?       @db.Text // Descrição otimizada pela IA
  perfilIdealJson Json?         // Perfil comportamental esperado
  publicToken     String?       @unique @default(cuid()) // Para link público de inscrição
  salaryMin       Decimal?      @db.Decimal(10, 2)
  salaryMax       Decimal?      @db.Decimal(10, 2)
  
  // Relação Multi-tenant: Toda vaga pertence a uma empresa
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("jobs")
  @@index([companyId, titulo, status])
  applications Application[]

}

model Candidate {
  id           String        @id @default(uuid())
  nome         String
  email        String        @unique
  telefone     String?
  curriculoUrl String?       // URL do PDF do currículo
  linkedinUrl  String?       // URL do perfil no LinkedIn

  respostasJson   Json?         // Respostas brutas dos testes
  testCompletedAt DateTime?
  
  // Relações
  applications Application[]
  personality     PersonalityResult?

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("candidates")
}

enum ApplicationStatus {
  PENDENTE
  EM_ANALISE
  TESTE_PSICOMETRICO
  ENTREVISTA
  APROVADO
  REPROVADO
}

model Application {
  id          String            @id @default(uuid())
  status      ApplicationStatus @default(PENDENTE)

  // Campos de IA
  feedbackIA     String?           @db.Text
  matchScore     Int?
  matchResultJson Json?

  testLinks    TestLink[]

  // Relacionamentos
  jobId       String
  job         Job               @relation(fields: [jobId], references: [id])
  
  candidateId String
  candidate   Candidate         @relation(fields: [candidateId], references: [id])

  // Facilitador para o Multi-tenancy (ajuda a listar todos os candidatos da empresa X rápido)
  companyId   String
  company     Company           @relation(fields: [companyId], references: [id])

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("applications")
}

model OrganogramaNode {
  id        String   @id @default(uuid())
  nome      String
  cargo     String
  parentId  String?  // Para criar a árvore hierárquica
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("organograma_nodes")
}

model PersonalityResult {
  id          String    @id @default(uuid())
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id])
  disc        String?   // Resultado simplificado DISC
  eneagrama   String?   // Resultado simplificado Eneagrama
  rawScore    Json?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("personality_results")
}

model TestLink {
  id            String      @id @default(uuid())
  token         String      @unique
  applicationId String
  application   Application @relation(fields: [applicationId], references: [id])
  expiresAt     DateTime

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("test_links")
}